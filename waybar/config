{
    "layer": "top",     // Top or bottom of applcations
    "position": "top",  // Position of the bar
    "spacing": 4,       // Gaps between modules (px)

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": ["hyprland/window"],
    "modules-right": [
        "pulseaudio",
        "network",
        "memory",
        "custom/disk",
        "battery",
        "clock",
        "custom/notification"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "tooltip": false,
        "all-outputs": true,
        "show-special": false,
        "on-click": ""
    },
    "hyprland/submap": {
        "format": "{}",
        "tooltip": false
    },
    "hyprland/window": {
        "format": "{title}",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} пЉ” ",
        "format-bluetooth-muted": "пЂ¦ пЉ” ",
        "format-muted": "пЂ¦ ",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "",
            "headset": "пЂҐ",
            "phone": "п‚•",
            "phone-muted": "оґ—",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "smooth-scrolling-threshold": 1
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) п‡« ",
        "format-ethernet": "{ipaddr}/{cidr} пћ–",
        "format-linked": "{ifname} (No IP) пћ–",
        "format-disconnected": "Disconnected вљ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip": true,
        "tooltip-format": "{ifname} via {gwaddr}"
    },
    "memory": {
        "interval": 30,
        "format": "{percentage}% п‹’ ",
        "tooltip-format": "Using {used:0.1f}GiB"
    },
    "custom/disk": {
        "interval": 30,
        "exec": "~/.config/waybar/disk.sh",
        "format": "{} п…› ",
        "tooltip": true,
        "return-type": "json"
    },
    "battery": {
        "interval": 30,
        "format": "{capacity}% {icon} ",
        "format-charging": "{capacity}% п‡¦ ",
        "format-plugged": "{capacity}% п‡¦ ",
        "states": {
            "full":   100,
            "tquart": 80,
            "half":   60,
            "quart":  40,
            "low":    20
        },
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
        "tooltip": true,
        "tooltip-format": "{timeTo}"
    },
    "clock": {
        "timezone": "Europe/Oslo",
        "format-alt": "{:%d-%m-%Y}",
        "tooltip": true,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "п‚ў <span foreground='red'><sup>п‘„</sup></span>",
            "none": "п‚ў ",
            "dnd-notification": "п‡· <span foreground='red'><sup>п‘„</sup></span>",
            "dnd-none": "п‡· ",
            "inhibited-notification": "п‚ў <span foreground='red'><sup>п‘„</sup></span>",
            "inhibited-none": "п‚ў ",
            "dnd-inhibited-notification": "п‡· <span foreground='red'><sup>п‘„</sup></span>",
            "dnd-inhibited-none": "п‡· "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
}

